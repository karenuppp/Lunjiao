# ============================================================
# Lunjiao - 部门智能问答系统 环境配置
# ============================================================

# ---- LLM / Model ----
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# ---- RAG-Anything (文档知识库检索) ----
# 部署方式: 通过 Docker Compose 启动 https://github.com/your-org/rag-anything
RAG_API_BASE=http://localhost:8023
RAG_API_KEY=

# ---- MCP Server (数据库查询 - 只读) ----
MCP_SERVER_BASE=http://localhost:8024

# ---- File Upload ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.xlsx,.xls,.pptx,.csv,.txt,.md,.png,.jpg,.jpeg

# ---- Database ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=lunjiao_db

# ---- Server ----
HOST=0.0.0.0
PORT=8000
DEBUG=true
