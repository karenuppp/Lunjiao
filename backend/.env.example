# ============================================================
# Zhiwei - 部门智能问答系统 环境配置
# ============================================================

# ---- LLM / Model ----
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-4o

# ---- Embedding（可独立于 LLM，不填则回退到 LLM 配置）----
EMBEDDING_API_KEY=sk-your-embedding-api-key-here
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_DIM=768
EMBEDDING_WORKERS=2

# ---- RAG ----
RAG_API_BASE=http://localhost:8023
RAG_API_KEY=
RAG_QUERY_TIMEOUT=30

# ---- MCP Server (数据库查询 - 只读) ----
MCP_SERVER_BASE=http://localhost:8024

# ---- File Upload ----
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50
RAG_INDEXING_TIMEOUT=300
RAG_FAST_INDEXING=true  # chunk+embed only, disable entity extraction for speed
ALLOWED_EXTENSIONS=.pdf,.docx,.doc,.xlsx,.xls,.pptx,.csv,.txt,.md,.png,.jpg,.jpeg

# ---- Database ----
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=zhiwei_db

# ---- Logging ----
LOG_DIR=./logs
LOG_LEVEL=INFO

# ---- Skill Downloads (generated files from skill scripts) ----
DOWNLOAD_DIR=./downloads

# ---- Sandbox (Docker code execution) ----
SANDBOX_ENABLED=true
SANDBOX_IMAGE=zhiwei-sandbox:latest
SANDBOX_TIMEOUT=60
SANDBOX_MAX_TIMEOUT=120
SANDBOX_MEMORY_LIMIT=256m
SANDBOX_CPU_QUOTA=50000
SANDBOX_CPU_PERIOD=100000
SANDBOX_MAX_OUTPUT_BYTES=102400
SANDBOX_TMPFS_SIZE_MB=64

# ---- Server ----
HOST=0.0.0.0
PORT=8000
DEBUG=true
